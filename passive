local function notify(title, text, duration)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title or "Sniper",
            Text = text,
            Duration = duration or 3
        })
    end)
    print("[Sniper] " .. text)
end

local function addLog(message)
    if Gui.LogBox then
        local timestamp = os.date("%H:%M:%S")
        Gui.LogBox.Text = "[" .. timestamp .. "] " .. message .. "\n" .. Gui.LogBox.Text
        local lines = Gui.LogBox.Text:split("\n")
        if #lines > 15 then
            table.remove(lines, #lines)
            Gui.LogBox.Text = table.concat(lines, "\n")
        end
    end
end

local function findRerollButton()
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
            local name = gui.Name:lower()
            local text = ""
            pcall(function() text = gui.Text:lower() end)
            if name:find("reroll") or text:find("reroll") or name:find("roll") or text:find("roll") then
                if gui.Visible and gui.Active then
                    return gui
                end
            end
        end
    end
    return nil
end

local function getDisplayedPassiveText()
    local texts = {}
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextLabel") and gui.Visible then
            local txt = gui.Text
            if txt and #txt > 5 then
                table.insert(texts, txt)
            end
        end
    end
    return table.concat(texts, " ")
end

local function parsePassiveData(rawText)
    if not rawText or rawText == "" then return nil, {} end
    local lowerText = rawText:lower()
    local passiveName = nil
    local stats = {}
    -- Tìm tên passive trong database (ưu tiên khớp chính xác)
    for name, _ in pairs(PassiveDatabase) do
        if lowerText:find(name:lower()) then
            passiveName = name
            break
        end
    end
    -- Parse các số theo tên stat của passive đã chọn
    if passiveName and PassiveDatabase[passiveName] then
        local statDefs = PassiveDatabase[passiveName].Stats
        for _, def in ipairs(statDefs) do
            local patterns = {
                "(%d+%.?%d*)%%?%s*" .. def.Name:lower(),
                "(%d+%.?%d*)%s*%-%s*%d+%.?%d*%%%s*" .. def.Name:lower()
            }
            for _, pat in ipairs(patterns) do
                local val = lowerText:match(pat)
                if val then
                    stats[def.Name] = tonumber(val)
                    break
                end
            end
        end
    end
    return passiveName, stats
end

local function clickButton(button)
    if not button then return false end
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        local pos = button.AbsolutePosition + button.AbsoluteSize / 2
        vim:SendMouseButtonEvent(pos, 0, 0, 0, true, game, 1)
        task.wait(0.05)
        vim:SendMouseButtonEvent(pos, 0, 0, 0, false, game, 1)
    end)
    pcall(function()
        for _, ev in ipairs(button:GetDescendants()) do
            if ev:IsA("GuiButton") then
                ev:InvokeServer()
                break
            end
        end
    end)
    return true
end

local function meetsRequirements(passiveName, stats)
    if not passiveName or passiveName ~= Sniper.TargetPassive then return false end
    local def = PassiveDatabase[Sniper.TargetPassive]
    if not def then return false end
    for _, statDef in ipairs(def.Stats) do
        local minVal = Sniper.MinStats[statDef.Name] or 0
        local actual = stats[statDef.Name] or 0
        if minVal > 0 and actual < minVal then
            return false
        end
    end
    return true
end

local function sniperLoop()
    while Sniper.Running do
        if not Sniper.RerollButton then
            Sniper.RerollButton = findRerollButton()
            if not Sniper.RerollButton then
                addLog("Không tìm thấy nút Reroll")
                task.wait(5)
                continue
            end
        end
        local rawText = getDisplayedPassiveText()
        local passiveName, stats = parsePassiveData(rawText)
        Sniper.RollCount = Sniper.RollCount + 1
        local statStr = ""
        for k, v in pairs(stats) do
            statStr = statStr .. string.format("%s:%.1f ", k, v)
        end
        addLog(string.format("Roll #%d: %s | %s", Sniper.RollCount, passiveName or "???", statStr))
        if meetsRequirements(passiveName, stats) then
            addLog(">>> ĐÃ TÌM THẤY PASSIVE MONG MUỐN! <<<")
            notify("THÀNH CÔNG!", passiveName .. " đạt yêu cầu!", 10)
            Sniper.Running = false
            if Gui.StartButton then Gui.StartButton.Text = "▶ BẮT ĐẦU SNIPE" end
            pcall(function()
                local sound = Instance.new("Sound")
                sound.SoundId = "rbxassetid://911310971"
                sound.Parent = workspace
                sound:Play()
                task.wait(1)
                sound:Destroy()
            end)
            break
        end
        if Sniper.RerollButton then clickButton(Sniper.RerollButton) end
        task.wait(Sniper.RerollDelay)
    end
    Sniper.RollCount = 0
    Sniper.RerollButton = nil
end

