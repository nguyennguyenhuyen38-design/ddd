-- ======================== UTILITY FUNCTIONS ========================
local function notify(title, text, duration)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title or "Sniper",
            Text = text,
            Duration = duration or 3
        })
    end)
    print("[Sniper] " .. text)
end

local function addLog(message)
    if Gui.LogBox then
        local timestamp = os.date("%H:%M:%S")
        Gui.LogBox.Text = "[" .. timestamp .. "] " .. message .. "\n" .. Gui.LogBox.Text
        -- Giới hạn dòng log
        local lines = Gui.LogBox.Text:split("\n")
        if #lines > 15 then
            table.remove(lines, #lines)
            Gui.LogBox.Text = table.concat(lines, "\n")
        end
    end
end

-- Tìm nút Reroll trên giao diện
local function findRerollButton()
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
            local name = gui.Name:lower()
            local text = ""
            pcall(function() text = gui.Text:lower() end)
            if name:find("reroll") or text:find("reroll") or name:find("roll") or text:find("roll") then
                if gui.Visible and gui.Active then
                    return gui
                end
            end
        end
    end
    return nil
end

-- Đọc text passive hiển thị
local function getDisplayedPassiveText()
    local texts = {}
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextLabel") and gui.Visible then
            local txt = gui.Text
            if txt and #txt > 5 then
                table.insert(texts, txt)
            end
        end
    end
    return table.concat(texts, " ")
end

-- Parse dữ liệu passive từ text
local function parsePassiveData(rawText)
    if not rawText or rawText == "" then
        return nil, {}
    end
    local lowerText = rawText:lower()
    local passiveName = nil
    local stats = {}
    
    -- Danh sách passive phổ biến
    local mythicals = {"fortune chosen", "executioner", "rampage"}
    for _, name in ipairs(mythicals) do
        if lowerText:find(name) then
            passiveName = name
            break
        end
    end
    
    -- Parse +1 Drop
    local dropPattern = "(%d+%.?%d*)%%?%s*for%s*%+1%s*drop"
    local dropVal = lowerText:match(dropPattern)
    if dropVal then
        stats.Drop = tonumber(dropVal)
    else
        local altPattern = "%+(%d+)%s*drop"
        local altVal = lowerText:match(altPattern)
        if altVal then stats.Drop = tonumber(altVal) end
    end
    
    -- Parse Luck
    local luckPattern = "(%d+%.?%d*)%%?%s*luck"
    local luckVal = lowerText:match(luckPattern)
    if luckVal then
        stats.Luck = tonumber(luckVal)
    else
        local rangePattern = "(%d+%.?%d*)%s*%-%s*%d+%.?%d*%%%s*luck"
        local rangeVal = lowerText:match(rangePattern)
        if rangeVal then stats.Luck = tonumber(rangeVal) end
    end
    
    -- Parse Damage
    local damagePattern = "(%d+%.?%d*)%%?%s*damage"
    local damageVal = lowerText:match(damagePattern)
    if damageVal then
        stats.Damage = tonumber(damageVal)
    else
        local rangePattern = "(%d+%.?%d*)%s*%-%s*%d+%.?%d*%%%s*damage"
        local rangeVal = lowerText:match(rangePattern)
        if rangeVal then stats.Damage = tonumber(rangeVal) end
    end
    
    return passiveName, stats
end

-- Click ảo vào button (mobile)
local function clickButton(button)
    if not button then return false end
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        local pos = button.AbsolutePosition + button.AbsoluteSize / 2
        vim:SendMouseButtonEvent(pos, 0, 0, 0, true, game, 1)
        task.wait(0.05)
        vim:SendMouseButtonEvent(pos, 0, 0, 0, false, game, 1)
    end)
    pcall(function()
        for _, ev in ipairs(button:GetDescendants()) do
            if ev:IsA("GuiButton") then
                ev:InvokeServer()
                break
            end
        end
    end)
    return true
end

-- Kiểm tra đạt yêu cầu
local function meetsRequirements(passiveName, stats)
    if not passiveName then return false end
    if passiveName:lower() ~= Sniper.TargetPassive:lower() then
        return false
    end
    if Sniper.MinDrop > 0 and (not stats.Drop or stats.Drop < Sniper.MinDrop) then
        return false
    end
    if Sniper.MinLuck > 0 and (not stats.Luck or stats.Luck < Sniper.MinLuck) then
        return false
    end
    if Sniper.MinDamage > 0 and (not stats.Damage or stats.Damage < Sniper.MinDamage) then
        return false
    end
    return true
end

-- ======================== SNIPER LOOP ========================
local function sniperLoop()
    while Sniper.Running do
        -- Tìm nút reroll nếu chưa có
        if not Sniper.RerollButton then
            Sniper.RerollButton = findRerollButton()
            if not Sniper.RerollButton then
                addLog("Không tìm thấy nút Reroll - kiểm tra lại giao diện")
                task.wait(5)
                continue
            end
        end
        
        -- Đọc text
        local rawText = getDisplayedPassiveText()
        local passiveName, stats = parsePassiveData(rawText)
        
        Sniper.RollCount = Sniper.RollCount + 1
        local logMsg = string.format("Roll #%d: %s | Drop:%.1f Luck:%.1f Dmg:%.1f",
            Sniper.RollCount,
            passiveName or "???",
            stats.Drop or 0,
            stats.Luck or 0,
            stats.Damage or 0
        )
        addLog(logMsg)
        
        -- Kiểm tra đạt yêu cầu
        if meetsRequirements(passiveName, stats) then
            addLog(">>> ĐÃ TÌM THẤY PASSIVE MONG MUỐN! <<<")
            notify("THÀNH CÔNG!", string.format("%s - Drop:%.1f Luck:%.1f Dmg:%.1f", passiveName, stats.Drop or 0, stats.Luck or 0, stats.Damage or 0), 10)
            Sniper.Running = false
            Gui.StartButton.Text = "BẮT ĐẦU SNIPE"
            -- Phát âm thanh
            pcall(function()
                local sound = Instance.new("Sound")
                sound.SoundId = "rbxassetid://911310971"
                sound.Parent = workspace
                sound:Play()
                task.wait(1)
                sound:Destroy()
            end)
            break
        end
        
        -- Click reroll
        if Sniper.RerollButton then
            clickButton(Sniper.RerollButton)
        end
        
        task.wait(Sniper.RerollDelay)
    end
    
    Sniper.RollCount = 0
    Sniper.RerollButton = nil
end

