    Gui.StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    Gui.StatusLabel.Font = Enum.Font.Gotham
    Gui.StatusLabel.TextSize = 13
    Gui.StatusLabel.LayoutOrder = 11
    Gui.StatusLabel.Parent = SettingsFrame

    -- Khởi tạo input cho passive mặc định
    updateStatsInputs("Fortune Chosen")

    -- Load/Save
    local function loadSettings()
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile("SniperSettings.json"))
        end)
        if success and data then
            if data.TargetPassive and PassiveDatabase[data.TargetPassive] then
                Sniper.TargetPassive = data.TargetPassive
                Gui.PassiveDropdownButton.Text = "🎯 " .. data.TargetPassive .. " [" .. PassiveDatabase[data.TargetPassive].Rarity .. "]"
                updateStatsInputs(data.TargetPassive)
                for statName, val in pairs(data.MinStats or {}) do
                    if Gui.StatInputs[statName] then
                        Gui.StatInputs[statName].Text = tostring(val)
                    end
                end
            end
            Gui.DelayBox.Text = tostring(data.RerollDelay or 3.5)
            addLog("Đã tải cấu hình")
        else
            addLog("Chưa có file cấu hình")
        end
    end

    local function saveSettings()
        local minStats = {}
        for statName, input in pairs(Gui.StatInputs) do
            minStats[statName] = tonumber(input.Text) or 0
        end
        local data = {
            TargetPassive = Sniper.TargetPassive,
            MinStats = minStats,
            RerollDelay = tonumber(Gui.DelayBox.Text) or 3.5
        }
        pcall(function()
            writefile("SniperSettings.json", HttpService:JSONEncode(data))
            addLog("Đã lưu cấu hình")
        end)
    end

    SaveButton.MouseButton1Click:Connect(saveSettings)
    LoadButton.MouseButton1Click:Connect(loadSettings)

    Gui.StartButton.MouseButton1Click:Connect(function()
        if Sniper.Running then
            Sniper.Running = false
            Gui.StartButton.Text = "▶ BẮT ĐẦU SNIPE"
            Gui.StatusLabel.Text = "⏸️ Đã dừng"
            Gui.StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 0)
            addLog("Dừng snipe")
        else
            -- Cập nhật MinStats từ GUI
            Sniper.MinStats = {}
            for statName, input in pairs(Gui.StatInputs) do
                Sniper.MinStats[statName] = tonumber(input.Text) or 0
            end
            Sniper.RerollDelay = tonumber(Gui.DelayBox.Text) or 3.5
            Sniper.Running = true
            Gui.StartButton.Text = "⏸️ DỪNG SNIPE"
            Gui.StatusLabel.Text = "🔄 Đang chạy..."
            Gui.StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            addLog("Bắt đầu snipe: " .. Sniper.TargetPassive)
            coroutine.wrap(sniperLoop)()
        end
    end)

    task.spawn(loadSettings)
    addLog("GUI Pro đã sẵn sàng. Chọn passive và nhập ngưỡng.")
end

if not game:IsLoaded() then game.Loaded:Wait() end
task.wait(1)
createGUI()
notify("Passive Sniper Pro", "GUI đã tải! Chọn passive từ danh sách.", 5)
