        elseif data.Rarity == "Legendary" then
            btn.BackgroundColor3 = Color3.fromRGB(200, 150, 50)
        elseif data.Rarity == "Epic" then
            btn.BackgroundColor3 = Color3.fromRGB(150, 50, 200)
        end
        
        btn.MouseButton1Click:Connect(function()
            Sniper.TargetPassive = name
            Gui.PassiveDropdownButton.Text = "🎯 " .. name .. " [" .. data.Rarity .. "]"
            updateStatsInputs(name)
            dropdownFrame.Visible = false
        end)
        totalHeight = totalHeight + 32
